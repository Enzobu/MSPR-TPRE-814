# ──────────────────────────────────────────────
# frontend-web — SPA React
# Copier en .env.local (gitignoré).
#
# ⚠ Toute variable VITE_* est PUBLIQUE (shipped dans le bundle).
#   Ne JAMAIS y mettre de secret.
# ──────────────────────────────────────────────

# Docker: exposé via BACKEND_CENTRAL_PORT dans /.env.compose
VITE_API_URL=http://localhost:3000

# Suivi des erreurs front (Sentry, ADR-0011). Vide = SDK no-op.
# VITE_SENTRY_DSN est PUBLIC (inliné au bundle) — fonctionnement normal d'un DSN
# navigateur Sentry, ce n'est PAS un secret.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
