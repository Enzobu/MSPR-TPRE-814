// ──────────────────────────────────────────────
// secrets.h — credentials WiFi + MQTT + identite capteur
//
// 1. Copier ce fichier en `include/secrets.h`
// 2. Remplir les valeurs
// 3. Ne JAMAIS commiter `secrets.h` (deja dans .gitignore)
//
// Le topic MQTT et le clientId NE sont PAS codes en dur ici : ils sont
// construits a partir de COUNTRY + WAREHOUSE_ID selon la convention
// ADR-0003 (futurekawa/{country}/warehouse/{warehouseId}/...).
// Voir src/topic.h.
// ──────────────────────────────────────────────
#pragma once

// WiFi
#define WIFI_SSID      "your-wifi-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// MQTT broker (Mosquitto local au pays)
#define MQTT_HOST      "192.168.1.10"
#define MQTT_PORT      1883
#define MQTT_USERNAME  ""               // laisser vide si pas d'auth
#define MQTT_PASSWORD  ""

// Identite du capteur (ADR-0003)
//   COUNTRY      ∈ "BR" | "EC" | "CO"  (CountryCode de @futurekawa/contracts)
//   WAREHOUSE_ID = code de l'entrepot (ex. "W1")
// A partir de ces deux valeurs sont derives :
//   - topic mesure : futurekawa/{COUNTRY}/warehouse/{WAREHOUSE_ID}/measurement
//   - topic statut : futurekawa/{COUNTRY}/warehouse/{WAREHOUSE_ID}/status
//   - clientId     : futurekawa-iot-{COUNTRY}-{WAREHOUSE_ID}
#define COUNTRY        "BR"
#define WAREHOUSE_ID   "W1"
