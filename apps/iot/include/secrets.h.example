// secrets.h — credentials WiFi + MQTT
//
// 1. Copier ce fichier en `include/secrets.h`
// 2. Remplir les valeurs
// 3. Ne JAMAIS commiter `secrets.h` (déjà dans .gitignore)
// ──────────────────────────────────────────────
#pragma once

// WiFi
#define WIFI_SSID      "your-wifi-ssid"
#define WIFI_PASSWORD  "your-wifi-password"

// MQTT broker (Mosquitto local au pays)
#define MQTT_HOST      "192.168.1.10"
#define MQTT_PORT      1883
#define MQTT_USERNAME  ""               // laisser vide si pas d'auth
#define MQTT_PASSWORD  ""
#define MQTT_CLIENT_ID "futurekawa-sensor-br-01"

// Topic de publication
// Convention : futurekawa/{country}/warehouse/{warehouseId}/measurement
#define MQTT_TOPIC     "futurekawa/BR/warehouse/W1/measurement"

// Fréquence de publication (ms)
#define PUBLISH_INTERVAL_MS 30000
