# Variables des tests d'intégration backend-pays (e2e).
#
# Valeurs JETABLES de la DB/broker de test (docker-compose.test.yml, stockage
# tmpfs) : la base repart à neuf à chaque `up`, ces identifiants ne sont donc PAS
# des secrets. Ce fichier est committé pour permettre un `pnpm test:e2e` zéro-config.
#
# Pour surcharger en local sans toucher au dépôt : copier ce fichier en
# `.env.test` (gitignoré) et y ajuster les valeurs. L'env réel (ex. CI) reste
# prioritaire sur ces deux fichiers.
COUNTRY_CODE=BR
DATABASE_URL=mysql://futurekawa:futurekawa@localhost:3399/futurekawa_pays_test
MQTT_URL=mqtt://localhost:1883

# Mailer d'alerte (#34) → faux SMTP MailDev (docker-compose.test.yml).
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_SECURE=false
SMTP_FROM=alerts@futurekawa.test
ALERT_RECIPIENT=responsable@futurekawa.test
# API REST de MailDev interrogée par le test pour vérifier la réception.
MAILDEV_API_URL=http://localhost:1081
