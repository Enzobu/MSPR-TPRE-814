# ──────────────────────────────────────────────
# backend-pays — 1 instance par pays
# Copier en .env et remplir. .env est gitignoré.
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3010
COUNTRY_CODE=BR                                    # BR | EC | CO — détermine les seuils via @futurekawa/contracts

# Base de données (MariaDB)
# Docker: mysql://futurekawa:futurekawa@mariadb-pays:3306/futurekawa_pays
DATABASE_URL=mysql://futurekawa:changeme@localhost:3306/futurekawa_pays

# Broker MQTT (local au pays)
# Docker: mqtt://mosquitto-pays:1883
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=backend-pays

# SMTP (alerting)
# Exemple OVH: SMTP_HOST=ssl0.ovh.net, SMTP_PORT=587, SMTP_SECURE=false
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com
ALERT_RECIPIENT=responsable@example.com
# Base de l'UI siège, insérée comme lien dans les emails d'alerte (ADR-0004).
CENTRAL_UI_URL=http://localhost:3000

# Observabilité
LOG_LEVEL=debug                                    # trace | debug | info | warn | error

# CORS (pour le backend-central qui tape ce backend)
# Liste blanche séparée par des virgules. Jamais '*' (rules 07-security).
CORS_ORIGIN=http://localhost:3000

# Rate limiting (@nestjs/throttler) — fenêtre + nombre de requêtes
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
