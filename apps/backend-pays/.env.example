# ──────────────────────────────────────────────
# backend-pays — 1 instance par pays
# Copier en .env et remplir. .env est gitignoré.
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3010
COUNTRY_CODE=BR                                    # BR | EC | CO — détermine les seuils via @futurekawa/contracts

# Base de données (MariaDB)
# Docker BR: mysql://futurekawa:futurekawa@mariadb-br:3306/futurekawa_pays_br
# Docker EC: mysql://futurekawa:futurekawa@mariadb-ec:3306/futurekawa_pays_ec
# Docker CO: mysql://futurekawa:futurekawa@mariadb-co:3306/futurekawa_pays_co
DATABASE_URL=mysql://futurekawa:changeme@localhost:3306/futurekawa_pays_br

# Broker MQTT (local au pays)
# Docker BR: mqtt://mosquitto-br:1883
# Docker EC: mqtt://mosquitto-ec:1883
# Docker CO: mqtt://mosquitto-co:1883
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=backend-pays-br

# SMTP (alerting)
# Docker: SMTP_HOST=maildev et SMTP_PORT=1025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@futurekawa.local
ALERT_RECIPIENT=responsable.br@futurekawa.local

# Observabilité
LOG_LEVEL=debug                                    # trace | debug | info | warn | error

# CORS (pour le backend-central qui tape ce backend)
CORS_ORIGIN=http://localhost:3000
