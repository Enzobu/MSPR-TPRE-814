# ──────────────────────────────────────────────
# backend-pays — PRODUCTION (1 instance par pays, CDC §V.2, #50)
# Modèle de variables prod. Secrets réels via gestionnaire de secrets du CI/CD,
# jamais commités. Copier/adapter, ne jamais committer .env.
# ──────────────────────────────────────────────

# Application
NODE_ENV=production
PORT=3000
COUNTRY_CODE=BR                              # BR | EC | CO — une valeur par instance

# Base de données (MariaDB pays) — hôte interne, mot de passe via secret manager
DATABASE_URL=mysql://futurekawa:__DB_PASSWORD__@mariadb-pays:3306/futurekawa_pays

# Broker MQTT (local au pays) — auth OBLIGATOIRE en prod (pas d'anonyme)
MQTT_URL=mqtt://mosquitto-pays:1883
MQTT_USERNAME=__MQTT_BACKEND_USER__
MQTT_PASSWORD=__MQTT_BACKEND_PASSWORD__
MQTT_CLIENT_ID=backend-pays

# SMTP (alerting) — identifiants via secret manager
SMTP_HOST=ssl0.ovh.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=__SMTP_USER__
SMTP_PASSWORD=__SMTP_PASSWORD__
SMTP_FROM=alerts@futurekawa.example
ALERT_RECIPIENT=responsable@futurekawa.example
CENTRAL_UI_URL=https://app.futurekawa.example

# Observabilité
LOG_LEVEL=info

# Suivi des erreurs (Sentry SaaS EU, ADR-0011). DSN du projet "backend-pays"
# fourni via le gestionnaire de secrets / env Dokploy (non commité).
SENTRY_DSN=https://__PUBLIC_KEY__@o4511597057409024.ingest.de.sentry.io/__PROJECT_ID__
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=__GIT_SHA__

# CORS — origine EXACTE du backend-central (qui appelle ce backend), jamais '*'
CORS_ORIGIN=https://central.internal.futurekawa.example

# Rate limiting (@nestjs/throttler) — resserré en prod
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
