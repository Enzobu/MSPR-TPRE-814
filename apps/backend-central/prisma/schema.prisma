// Schéma Prisma — backend-central (MariaDB : DB siège légère users/config/audit).
// Le client est généré dans ../src/generated/prisma (gitignoré, régénéré au build).
// runtime/moduleFormat: client CJS compatible NestJS + driver adapter MariaDB.
// Voir docs/architecture/database.md pour le modèle complet (à venir avec les features).

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

// La connexion est fournie au runtime par le driver adapter MariaDB
// (PrismaService). La url pour `prisma migrate` vient de prisma.config.ts.
datasource db {
  provider = "mysql"
}
