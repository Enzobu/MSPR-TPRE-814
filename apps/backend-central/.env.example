# ──────────────────────────────────────────────
# backend-central — siège, agrégateur
# Copier en .env et remplir. .env est gitignoré.
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# Base de données (MariaDB — DB siège légère : users, config, audit)
# Docker: mysql://futurekawa:futurekawa@mariadb-central:3306/futurekawa_central
DATABASE_URL=mysql://futurekawa:changeme@localhost:3306/futurekawa_central

# Backends pays (URLs internes)
# Docker mono-pays: les trois variables peuvent pointer vers http://backend-pays:3000
BACKEND_PAYS_BR_URL=http://localhost:3010
BACKEND_PAYS_EC_URL=http://localhost:3010
BACKEND_PAYS_CO_URL=http://localhost:3010

# Résilience appels pays (ADR-0007)
PAYS_REQUEST_TIMEOUT_MS=3000
PAYS_REQUEST_RETRIES=2
PAYS_RETRY_BASE_MS=200                  # base du backoff exponentiel + jitter
PAYS_BREAKER_FAILURE_THRESHOLD=5        # échecs consécutifs avant ouverture du breaker
PAYS_BREAKER_COOLDOWN_MS=30000          # cooldown avant sonde half-open
STOCKS_CACHE_TTL_MS=60000               # cache court de /stocks ; 0 = désactivé

# CORS (origine frontend) — liste blanche séparée par des virgules, jamais '*'
CORS_ORIGIN=http://localhost:5173

# Rate limiting (@nestjs/throttler)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Auth (ADR-0006)
# JWT_SECRET est REQUIS au boot (≥ 32 caractères) : l'app refuse de démarrer sans.
JWT_SECRET=change-me-to-a-long-random-string-32-min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Seed de l'utilisateur ADMIN initial (prisma db seed). Requis seulement pour le
# seed, pas pour démarrer le serveur. À changer en prod (#50).
SEED_ADMIN_EMAIL=admin@futurekawa.local
SEED_ADMIN_PASSWORD=Adm1n-FutureKawa

# Observabilité
LOG_LEVEL=debug
