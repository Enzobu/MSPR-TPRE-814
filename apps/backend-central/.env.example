# ──────────────────────────────────────────────
# backend-central — siège, agrégateur
# Copier en .env et remplir. .env est gitignoré.
# ──────────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# Base de données (MariaDB — DB siège légère : users, config, audit)
# Docker: mysql://futurekawa:futurekawa@mariadb-central:3306/futurekawa_central
DATABASE_URL=mysql://futurekawa:changeme@localhost:3306/futurekawa_central

# Backends pays (URLs internes)
# Docker: http://backend-pays-br:3000, http://backend-pays-ec:3000, http://backend-pays-co:3000
BACKEND_PAYS_BR_URL=http://localhost:3010
BACKEND_PAYS_EC_URL=http://localhost:3011
BACKEND_PAYS_CO_URL=http://localhost:3012

# Résilience appels pays
PAYS_REQUEST_TIMEOUT_MS=3000
PAYS_REQUEST_RETRIES=2

# CORS (origine frontend)
CORS_ORIGIN=http://localhost:5173

# Auth (à préciser via ADR-0006)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Observabilité
LOG_LEVEL=debug
