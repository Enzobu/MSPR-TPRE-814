{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm -r build)",
      "Bash(pnpm -r lint)",
      "Bash(pnpm -r test)",
      "Bash(pnpm --filter *:*)",
      "Bash(pnpm exec prisma:*)",
      "Bash(pnpm dlx shadcn*)",
      "Bash(pnpm run *)",
      "Bash(pnpm dev)",
      "Bash(pnpm build)",
      "Bash(pnpm lint)",
      "Bash(pnpm test)",
      "Bash(pnpm test:*)",
      "Bash(pnpm format)",
      "Bash(docker compose up*)",
      "Bash(docker compose down*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose build*)",
      "Bash(docker compose exec*)",
      "Bash(docker compose restart*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(pio run)",
      "Bash(pio run:*)",
      "Bash(pio device:*)",
      "Bash(pio test)",
      "Bash(pio test:*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git reset*)",
      "Bash(docker compose down -v)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  }
}
