# ════════════════════════════════════════════════════════════════
# .env.compose — configuration de la stack Docker Compose locale.
#
# Copier en .env.compose (gitignoré) :  cp .env.compose.example .env.compose
# Les valeurs ci-dessous sont des défauts de DEV fonctionnels : un
# `cp` + `make build && make up` démarre la stack telle quelle.
# ⚠ À surcharger impérativement en prod (mots de passe, JWT_SECRET, DSN…).
# ════════════════════════════════════════════════════════════════

COMPOSE_PROJECT_NAME=futurekawa

# ── URLs publiques (browser-facing : localhost:<port publié>) ─────
FRONTEND_WEB_URL=http://localhost:5173
BACKEND_CENTRAL_URL=http://localhost:3000
BACKEND_PAYS_URL=http://localhost:3000
PHPMYADMIN_WEB_URL=http://localhost:8080
DOCS_WEB_URL=http://localhost:8081

# phpMyAdmin : serveurs MariaDB listés dans le menu déroulant de login
PHPMYADMIN_HOSTS=mariadb-central,mariadb-pays
PHPMYADMIN_VERBOSES=central,pays

# URL interne (réseau Docker) du backend pays, appelé par le siège
BACKEND_PAYS_INTERNAL_URL=http://backend-pays:3000

# CORS : origine du front (jamais '*' — rules/07-security.md)
BACKEND_CENTRAL_CORS_ORIGIN=http://localhost:5173
BACKEND_PAYS_CORS_ORIGIN=http://localhost:5173

# ── Ports publiés sur l'hôte ─────────────────────────────────────
FRONTEND_WEB_PORT=5173
DOCS_WEB_PORT=8081
BACKEND_CENTRAL_PORT=3000
BACKEND_PAYS_PORT=3001
MARIADB_CENTRAL_PORT=3309
MARIADB_PAYS_PORT=3308
MOSQUITTO_PAYS_PORT=1883
PHPMYADMIN_WEB_PORT=8080

# ── Bases MariaDB (dev) ──────────────────────────────────────────
MARIADB_ROOT_PASSWORD=root
MARIADB_USER=futurekawa
MARIADB_PASSWORD=futurekawa
MARIADB_CENTRAL_DATABASE=futurekawa_central
MARIADB_PAYS_DATABASE=futurekawa_pays
COUNTRY_CODE=BR

# Connexions DB consommées par les backends (réseau Docker : nom de service + 3306)
DATABASE_CENTRAL_URL=mysql://futurekawa:futurekawa@mariadb-central:3306/futurekawa_central
DATABASE_PAYS_URL=mysql://futurekawa:futurekawa@mariadb-pays:3306/futurekawa_pays

# ── MQTT (réseau Docker interne) ─────────────────────────────────
MQTT_PAYS_URL=mqtt://mosquitto-pays:1883

# Auth Mosquitto (dev) — users générés au démarrage du broker
MQTT_IOT_USERNAME=iot
MQTT_IOT_PASSWORD=iotpass
MQTT_BACKEND_USERNAME=backend
MQTT_BACKEND_PASSWORD=backendpass

# ── SMTP (dev) ───────────────────────────────────────────────────
# Valeurs factices : l'alerting démarre mais n'enverra rien tant qu'un
# vrai SMTP n'est pas branché. Pour tester l'envoi, pointer vers un
# Mailpit/Mailhog local (SMTP_HOST + SMTP_PORT).
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
ALERT_SMTP_FROM=alerts@futurekawa.local
ALERT_RECIPIENT=ops@futurekawa.local

# ── Auth siège (backend-central) ─────────────────────────────────
# JWT_SECRET REQUIS (≥ 32 caractères) : l'app refuse de démarrer sans.
# SEED_ADMIN_* = admin initial créé au boot (seed idempotent). À CHANGER en prod.
JWT_SECRET=dev-local-jwt-secret-change-me-32chars-min
SEED_ADMIN_EMAIL=admin@futurekawa.local
SEED_ADMIN_PASSWORD=Adm1n-FutureKawa

# ── Suivi des erreurs (Sentry, ADR-0011) ─────────────────────────
# Laisser vide pour désactiver (SDK no-op). DSN front = PUBLIC (normal).
BACKEND_CENTRAL_SENTRY_DSN=
BACKEND_PAYS_SENTRY_DSN=
FRONTEND_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
# Upload des sourcemaps front (optionnel) : SECRET CI/Dokploy.
SENTRY_AUTH_TOKEN=

# ── Volumes (dossier gitignoré, créé au premier `up`) ────────────
VOLUME_BASE_PATH=./volumes
