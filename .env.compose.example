COMPOSE_PROJECT_NAME=

FRONTEND_WEB_URL=
BACKEND_CENTRAL_URL=
BACKEND_PAYS_URL=
BACKEND_PAYS_INTERNAL_URL=
BACKEND_CENTRAL_CORS_ORIGIN=
BACKEND_PAYS_CORS_ORIGIN=
PHPMYADMIN_WEB_URL=
PHPMYADMIN_HOSTS=
PHPMYADMIN_VERBOSES=
DOCS_WEB_URL=

FRONTEND_WEB_PORT=
DOCS_WEB_PORT=
BACKEND_CENTRAL_PORT=

BACKEND_PAYS_PORT=

MARIADB_CENTRAL_PORT=
MARIADB_PAYS_PORT=

MOSQUITTO_PAYS_PORT=

PHPMYADMIN_WEB_PORT=

MARIADB_ROOT_PASSWORD=
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_CENTRAL_DATABASE=
MARIADB_PAYS_DATABASE=
COUNTRY_CODE=

DATABASE_CENTRAL_URL=
DATABASE_PAYS_URL=

MQTT_PAYS_URL=

# Auth Mosquitto (dev) — users générés au démarrage du broker + utilisés par backend-pays
MQTT_IOT_USERNAME=
MQTT_IOT_PASSWORD=
MQTT_BACKEND_USERNAME=
MQTT_BACKEND_PASSWORD=

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=

ALERT_SMTP_FROM=
ALERT_RECIPIENT=

# Auth siège (backend-central). JWT_SECRET REQUIS (>= 32 caractères aléatoires) :
# l'app refuse de démarrer sans. SEED_ADMIN_* = admin initial créé au boot (seed
# idempotent via entrypoint) ; à changer après le premier login.
JWT_SECRET=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Suivi des erreurs (Sentry SaaS, région EU — ADR-0011, ticket #127).
# Laisser vide pour désactiver (SDK no-op). Un DSN par projet Sentry.
# - DSN backend = traité comme config sensible (env Dokploy, non commité).
# - DSN front  = PUBLIC (inliné dans le bundle), c'est normal.
BACKEND_CENTRAL_SENTRY_DSN=
BACKEND_PAYS_SENTRY_DSN=
FRONTEND_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
# Upload des sourcemaps front (optionnel) : org auth token, SECRET CI/Dokploy.
SENTRY_AUTH_TOKEN=
